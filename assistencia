const cacheCepCliente = {};
async function geocodificaCepCliente(cep) {
    if (cacheCepCliente[cep]) return cacheCepCliente[cep];
    try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), TIMEOUT_CEP_MS);
        const r = await fetch(`https://brasilapi.com.br/api/cep/v2/${cep}`, { signal: controller.signal });
        clearTimeout(timeoutId);
        if (r.ok) {
            const data = await r.json();
            const coords = data.location?.coordinates;
            if (coords?.latitude && coords?.longitude) {
                const result = {
                    lat: parseFloat(coords.latitude),
                    lng: parseFloat(coords.longitude),
                    cidade: data.city, uf: data.state
                };
                cacheCepCliente[cep] = result;
                return result;
            }
            if (data.city) {
                const result = { lat: null, lng: null, cidade: data.city, uf: data.state };
                cacheCepCliente[cep] = result;
                return result;
            }
        }
    } catch (e) {}
    try {
        const r2 = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
        if (r2.ok) {
            const data = await r2.json();
            if (!data.erro) {
                const result = { lat: null, lng: null, cidade: data.localidade, uf: data.uf };
                cacheCepCliente[cep] = result;
                return result;
            }
        }
    } catch (e) {}
    return null;
}

const cacheCidadeAutorizada = {};
async function enriqueceCidadeViaCep(cep) {
    if (cacheCidadeAutorizada[cep]) return cacheCidadeAutorizada[cep];
    try {
        const r = await fetch(`https://brasilapi.com.br/api/cep/v2/${cep}`);
        if (r.ok) {
            const data = await r.json();
            const result = {
                cidade: data.city || null,
                uf: data.state || null,
                lat: data.location?.coordinates?.latitude ? parseFloat(data.location.coordinates.latitude) : null,
                lng: data.location?.coordinates?.longitude ? parseFloat(data.location.coordinates.longitude) : null,
            };
            cacheCidadeAutorizada[cep] = result;
            return result;
        }
    } catch (e) {}
    try {
        const r2 = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
        if (r2.ok) {
            const data = await r2.json();
            if (!data.erro) {
                const result = { cidade: data.localidade || null, uf: data.uf || null, lat: null, lng: null };
                cacheCidadeAutorizada[cep] = result;
                return result;
            }
        }
    } catch (e) {}
    cacheCidadeAutorizada[cep] = { cidade: null, uf: null, lat: null, lng: null };
    return cacheCidadeAutorizada[cep];
}

