// ============================================================
function registraBusca(payload) {
    // Dispara e esquece: não bloqueia a UI, não trava se falhar
    if (!URL_CAPTURA || URL_CAPTURA.startsWith('COLE_AQUI')) return;
    try {
        fetch(URL_CAPTURA, {
            method: 'POST',
            mode: 'no-cors', // evita CORS, não esperamos resposta
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify(payload),
            keepalive: true
        }).catch(() => {}); // silencia qualquer erro
    } catch (e) { /* silencia */ }
}

