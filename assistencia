async function executaBusca() {
    const input = document.getElementById('search-input');
    const cep = limpaCep(input.value);
    const hint = document.getElementById('search-hint');
    const btn = document.getElementById('search-btn');

    if (cep.length !== 8) {
        hint.textContent = 'CEP inválido. Digite os 8 dígitos do seu CEP.';
        hint.classList.add('hint-erro');
        input.focus();
        return;
    }
    return executaBuscaPorCep(cep);
}

// ============================================================
// BUSCA POR CEP (fluxo principal — distância real)
// ============================================================
async function executaBuscaPorCep(cep) {
    const hint = document.getElementById('search-hint');
    const btn = document.getElementById('search-btn');
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spin"><iconify-icon icon="lucide:loader-2"></iconify-icon></span> Buscando...';
    hint.textContent = 'Localizando seu CEP...';
    hint.classList.remove('hint-erro');

    const geoCliente = await geocodificaCepCliente(cep);
    if (!geoCliente || !geoCliente.cidade) {
        btn.disabled = false;
        btn.innerHTML = original;
        hint.textContent = 'Não conseguimos localizar esse CEP. Verifique se está correto.';
        hint.classList.add('hint-erro');
        return;
    }

    const cidadeCliente = geoCliente.cidade;
    const ufCliente = geoCliente.uf;
    hint.textContent = `Buscando em ${cidadeCliente} - ${ufCliente}...`;

    let lista = dados.slice();
    if (filtroMp) lista = lista.filter(d => d.atende_monitores_pressao);

    const candidatosEstado = lista.filter(d => d.endereco.uf === ufCliente);

    btn.innerHTML = '<span class="spin"><iconify-icon icon="lucide:loader-2"></iconify-icon></span> Comparando autorizadas...';
    hint.textContent = `Comparando ${candidatosEstado.length} autorizada(s) em ${ufCliente}...`;

    const enriquecidas = [];
    const LOTE = 8;
    for (let i = 0; i < candidatosEstado.length; i += LOTE) {
        const lote = candidatosEstado.slice(i, i + LOTE);
        const resultados = await Promise.all(lote.map(async item => {
            const cepItem = item.endereco.cep;
            if (!cepItem) return { item, cidade: item.endereco.cidade, uf: item.endereco.uf, lat: null, lng: null };
            const geoItem = await enriqueceCidadeViaCep(cepItem);
            return {
                item,
                cidade: item.endereco.cidade || geoItem.cidade,
                uf: item.endereco.uf || geoItem.uf,
                lat: geoItem.lat,
                lng: geoItem.lng
            };
        }));
        enriquecidas.push(...resultados);
    }

    // 1ª PASSADA: mesma cidade
    const mesmaCidade = enriquecidas.filter(x => normCidade(x.cidade) === normCidade(cidadeCliente));

    btn.disabled = false;
    btn.innerHTML = original;

    if (mesmaCidade.length > 0) {
        const comDist = mesmaCidade.map(x => {
            let dist = null;
            if (geoCliente.lat != null && x.lat != null) {
                dist = distanciaKm(geoCliente.lat, geoCliente.lng, x.lat, x.lng);
            }
            return { item: x.item, dist };
        }).sort((a, b) => {
            if (a.dist != null && b.dist != null) return a.dist - b.dist;
            if (a.dist != null) return -1;
            if (b.dist != null) return 1;
            return 0;
        });
        const html = comDist.map(x => montaCardHTML(x.item, x.dist)).join('');
        const filtroTxt = filtroMp ? ' que atendem monitor de pressão' : '';
        hint.textContent = `${mesmaCidade.length} autorizada(s) em ${cidadeCliente}.`;
        registraBusca({
            cep, cidade: cidadeCliente, estado: ufCliente,
            resultado: 'encontrou_cidade',
            filtro_mp: filtroMp,
            distancia_mais_proxima_km: comDist[0]?.dist != null ? comDist[0].dist.toFixed(2) : ''
        });
        exibeResultados(html, `Autorizadas em ${cidadeCliente}`,
            `${mesmaCidade.length} resultado${mesmaCidade.length>1?'s':''}${filtroTxt}`, null, false);
        return;
    }

    // 2ª PASSADA: raio 20km
    if (geoCliente.lat != null) {
        const comDist = enriquecidas
            .filter(x => x.lat != null)
            .map(x => ({ item: x.item, cidade: x.cidade, dist: distanciaKm(geoCliente.lat, geoCliente.lng, x.lat, x.lng) }))
            .sort((a, b) => a.dist - b.dist);
        const dentroRaio = comDist.filter(x => x.dist <= RAIO_KM);
        if (dentroRaio.length > 0) {
            const html = dentroRaio.map(x => montaCardHTML(x.item, x.dist)).join('');
            const filtroTxt = filtroMp ? ' que atendem monitor de pressão' : '';
            hint.textContent = `${dentroRaio.length} autorizada(s) em até ${RAIO_KM} km de ${cidadeCliente}.`;
            registraBusca({
                cep, cidade: cidadeCliente, estado: ufCliente,
                resultado: 'encontrou_raio',
                filtro_mp: filtroMp,
                distancia_mais_proxima_km: dentroRaio[0].dist.toFixed(2)
            });
            exibeResultados(html, `Autorizadas próximas de ${cidadeCliente}`,
                `${dentroRaio.length} em até ${RAIO_KM} km${filtroTxt}`,
                `Não há autorizada na cidade de ${cidadeCliente}, mas encontramos opções em até ${RAIO_KM} km.`, false);
            return;
        }
        if (comDist.length > 0) {
            const maisProxima = comDist[0];
            const html = montaCardHTML(maisProxima.item, maisProxima.dist);
            const filtroTxt = filtroMp ? ' que atende monitor de pressão' : '';
            hint.textContent = `Mais próxima a ${formataDistancia(maisProxima.dist)} de você.`;
            registraBusca({
                cep, cidade: cidadeCliente, estado: ufCliente,
                resultado: 'fora_raio',
                filtro_mp: filtroMp,
                distancia_mais_proxima_km: maisProxima.dist.toFixed(2)
            });
            exibeResultados(html, 'Mais próxima de você',
                `Fora do raio de ${RAIO_KM} km`,
                `Não há autorizada${filtroTxt} em ${cidadeCliente} nem em até ${RAIO_KM} km. A mais próxima fica em <strong>${maisProxima.cidade || maisProxima.item.endereco.uf}</strong>, a <strong>${formataDistancia(maisProxima.dist)}</strong>.`, true);
            return;
        }
    }

    // 3ª PASSADA: sem autorizadas próximas
    registraBusca({
        cep, cidade: cidadeCliente, estado: ufCliente,
        resultado: 'sem_resultado',
        filtro_mp: filtroMp,
        distancia_mais_proxima_km: ''
    });
    exibeResultados('', 'Sem autorizadas próximas', '',
        `Poxa, que pena... Ainda não temos uma assistência autorizada na sua região, mas seguimos expandindo nossa rede para oferecer um atendimento cada vez melhor.<br><br>Entre em contato com a nossa equipe que vamos te orientar da melhor forma possível.`,
        true);
}

// ============================================================
// VER TODAS — agrupamento por estado (ordem alfabética)
// ============================================================
const UF_NOMES_COMPLETOS = {
    'AC': 'Acre', 'AL': 'Alagoas', 'AM': 'Amazonas', 'AP': 'Amapá',
    'BA': 'Bahia', 'CE': 'Ceará', 'DF': 'Distrito Federal', 'ES': 'Espírito Santo',
    'GO': 'Goiás', 'MA': 'Maranhão', 'MG': 'Minas Gerais', 'MS': 'Mato Grosso do Sul',
    'MT': 'Mato Grosso', 'PA': 'Pará', 'PB': 'Paraíba', 'PE': 'Pernambuco',
    'PI': 'Piauí', 'PR': 'Paraná', 'RJ': 'Rio de Janeiro', 'RN': 'Rio Grande do Norte',
    'RO': 'Rondônia', 'RR': 'Roraima', 'RS': 'Rio Grande do Sul', 'SC': 'Santa Catarina',
    'SE': 'Sergipe', 'SP': 'São Paulo', 'TO': 'Tocantins'
};

function montaCardMiniHTML(item) {
    const e = item.endereco;
    const c = item.contato;
    const cidadeFinal = e.cidade || '';
    const localBase = [e.bairro, cidadeFinal].filter(Boolean).join(', ');
    const local = e.uf ? (localBase ? `${localBase} - ${e.uf}` : e.uf) : localBase;

    const enderecoCompleto = encodeURIComponent(
        [e.rua, e.numero, e.bairro, cidadeFinal, e.uf, 'CEP ' + formataCepExibicao(e.cep)].filter(Boolean).join(', ')
    );
    const urlMaps = `https://www.google.com/maps/search/?api=1&query=${enderecoCompleto}`;
    const msgWpp = encodeURIComponent(`Olá, ${item.nome_fantasia}! Encontrei o contato pelo site da Dellamed e preciso de assistência técnica.`);
    const urlWpp = c.whatsapp ? `https://wa.me/${c.whatsapp}?text=${msgWpp}` : '';

    const badgeMp = item.atende_monitores_pressao
        ? `<span class="badge-mini-mp">Monitor de pressão</span>` : '';

    return `
    <div class="card-mini">
      <div class="card-mini-top">
        <div class="card-mini-nome">${item.nome_fantasia}</div>
        ${badgeMp}
      </div>
      <div class="card-mini-local">
        <iconify-icon icon="lucide:map-pin" stroke-width="1.5"></iconify-icon>
        <span>${local || 'Endereço disponível ao contatar'}</span>
      </div>
      <div class="card-mini-acoes">
        ${urlWpp ? `<a class="btn-mini btn-mini-wpp" href="${urlWpp}" target="_blank" rel="noopener">
          <iconify-icon icon="lucide:message-circle" stroke-width="1.5"></iconify-icon>WhatsApp
        </a>` : ''}
        <a class="btn-mini btn-mini-rotas" href="${urlMaps}" target="_blank" rel="noopener">
          <iconify-icon icon="lucide:map" stroke-width="1.5"></iconify-icon>Como chegar
        </a>
      </div>
    </div>`;
}

function renderizaTodas() {
    let lista = dados.slice();
    if (filtroMp) lista = lista.filter(d => d.atende_monitores_pressao);

    // Agrupa por UF
    const porUf = {};
    for (const item of lista) {
        const uf = item.endereco.uf;
        if (!uf) continue;
        if (!porUf[uf]) porUf[uf] = [];
        porUf[uf].push(item);
    }

    // Ordena UFs alfabeticamente pelo NOME completo do estado (Acre, Alagoas, Amapá...)
    const ufsOrdenadas = Object.keys(porUf).sort((a, b) => {
        const nomeA = UF_NOMES_COMPLETOS[a] || a;
        const nomeB = UF_NOMES_COMPLETOS[b] || b;
        return nomeA.localeCompare(nomeB, 'pt-BR');
    });

    const html = ufsOrdenadas.map(uf => {
        const itens = porUf[uf]
            .sort((a, b) => (a.endereco.cidade || '').localeCompare(b.endereco.cidade || '', 'pt-BR'));
        return `
          <div class="uf-bloco">
            <h3 class="uf-titulo">
              <span class="uf-sigla">${uf}</span>
              ${UF_NOMES_COMPLETOS[uf] || uf}
              <span class="uf-count">${itens.length} ${itens.length === 1 ? 'autorizada' : 'autorizadas'}</span>
            </h3>
            <div class="cards-lista">
              ${itens.map(montaCardMiniHTML).join('')}
            </div>
          </div>`;
    }).join('');

    document.getElementById('todas-conteudo').innerHTML = html;
    const filtroTxt = filtroMp ? ' que atendem monitor de pressão' : '';
    document.getElementById('todas-count').textContent =
        `${lista.length} ${lista.length === 1 ? 'autorizada' : 'autorizadas'}${filtroTxt}`;
}

function toggleVerTodas() {
    const area = document.getElementById('todas-area');
    const btn = document.getElementById('btn-ver-todas');
    const label = document.getElementById('btn-ver-todas-label');
    const aberto = !area.classList.contains('hidden');

    if (aberto) {
        area.classList.remove('show');
        area.classList.add('hidden');
        area.setAttribute('aria-hidden', 'true');
        btn.classList.remove('aberto');
        btn.setAttribute('aria-expanded', 'false');
        label.textContent = 'Ver todas as autorizadas';
    } else {
        renderizaTodas();
        area.classList.remove('hidden');
        void area.offsetWidth;
        area.classList.add('show');
        area.setAttribute('aria-hidden', 'false');
        btn.classList.add('aberto');
        btn.setAttribute('aria-expanded', 'true');
        label.textContent = 'Recolher lista';
        const y = area.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: y, behavior: 'smooth' });
    }
}

// ============================================================
// ENRIQUECIMENTO DE CIDADES EM BACKGROUND
// ============================================================
async function enriqueceTodasAutorizadas() {
    const LOTE = 6;
    const semCidade = dados.filter(d => !d.endereco.cidade && d.endereco.cep);
    for (let i = 0; i < semCidade.length; i += LOTE) {
        const lote = semCidade.slice(i, i + LOTE);
        await Promise.all(lote.map(async item => {
            const geo = await enriqueceCidadeViaCep(item.endereco.cep);
            if (geo?.cidade) item.endereco.cidade = geo.cidade;
        }));
    }
    // Re-renderiza "Ver todas" se estiver aberto
    if (!document.getElementById('todas-area').classList.contains('hidden')) {
        renderizaTodas();
    }
}

// ============================================================
// INIT
// ============================================================
async function init() {
    dados = DADOS_EMBUTIDOS;

    // Enriquece cidades em background (não bloqueia a UI)
    enriqueceTodasAutorizadas();

    const input = document.getElementById('search-input');
    const btn = document.getElementById('search-btn');

    input.addEventListener('input', (e) => { e.target.value = formataCepInput(e.target.value); });
    input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); executaBusca(); }
    });
    btn.addEventListener('click', executaBusca);

    // Botão Ver Todas
    document.getElementById('btn-ver-todas').addEventListener('click', toggleVerTodas);

    document.querySelectorAll('input[name="produto"]').forEach(radio => {
        radio.addEventListener('change', (e) => {
            filtroMp = e.target.value === 'mp';
            document.getElementById('produto-aviso').style.display = filtroMp ? '' : 'none';
            // Se já tem busca exibida, refaz com o filtro novo
            if (!document.getElementById('results-area').classList.contains('hidden') && input.value.trim()) {
                executaBusca();
            }
            // Se a lista completa está aberta, re-renderiza com o filtro novo
            if (!document.getElementById('todas-area').classList.contains('hidden')) {
                renderizaTodas();
            }
        });
    });
}
document.addEventListener('DOMContentLoaded', init);
</script>
